{
  "appId": "com.nonotv.app",
  "appName": "NonoTV",
  "webDir": "dist",
  "overrideUserAgent": "VLC/3.0.18 LibVLC/3.0.18",
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "server": {
    "androidScheme": "http",
    "hostname": "localhost",
    "cleartext": true,
    "allowNavigation": ["*"]
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1A1A1A",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK",
      "resizeOnFullScreen": true
    },
    "CapacitorHttp": {
      "enabled": true
    }
  }
}
