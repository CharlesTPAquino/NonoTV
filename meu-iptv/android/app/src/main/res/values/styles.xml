<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema base do app -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- Fundo da SplashScreen e transições — preto como seu bg -->
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowIsTranslucent">false</item>

        <!-- Status bar escura (ícones brancos) -->
        <item name="android:statusBarColor">#1A1A1A</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar (barra de botões de sistema) -->
        <item name="android:navigationBarColor">#1A1A1A</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Remove a barra de título nativa -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Tema Splash (Padrão do Capacitor) -->
    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme">
        <item name="android:windowBackground">@color/black</item>
    </style>

    <!-- Tema do player em fullscreen imersivo -->
    <style name="AppTheme.Fullscreen" parent="AppTheme">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

</resources>